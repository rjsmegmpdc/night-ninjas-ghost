{
  "name": "ghost",
  "version": "0.1.0",
  "private": true,
  "description": "GHOST — Night Ninjas training tracker. Vite + React PWA + Tauri 2. Zero backend.",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "tokens": "vite-node --options.deps.inline=@material/material-color-utilities scripts/generate-m3-tokens.mjs",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.105.0",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "date-fns-tz": "^3.2.0",
    "lucide-react": "^0.460.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router": "^7.6.0",
    "recharts": "^2.13.3",
    "tailwind-merge": "^2.5.4",
    "wa-sqlite": "^1.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@material/material-color-utilities": "^0.4.0",
    "@tailwindcss/vite": "^4.0.0",
    "@tauri-apps/cli": "^2.0.0",
    "@types/node": "^22.9.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.6.3",
    "vite": "^6.0.0",
    "vite-plugin-pwa": "^0.21.0",
    "vitest": "^2.1.4"
  },
  "engines": {
    "node": ">=20.11.0"
  }
}
