{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "GHOST",
  "version": "0.1.0",
  "identifier": "com.nightninjas.ghost",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "GHOST",
        "width": 1280,
        "height": 900,
        "minWidth": 960,
        "minHeight": 640,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'wasm-unsafe-eval'; style-src 'self' 'unsafe-inline'; connect-src 'self' https://www.strava.com https://ghost-strava-oauth.onlinemyassistant.workers.dev https://api.anthropic.com; img-src 'self' data: https://dgtzuqphqg23d.cloudfront.net ipc: asset:"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
